{
    "name": "AegisFA - Full Stack",
    "dockerComposeFile": "docker-compose.yml",
    "service": "backend",
    "workspaceFolder": "/workspaces",
    "features": {
        "ghcr.io/devcontainers/features/node:2": {
            "version": "18"
        }
    },
    "forwardPorts": [5001, 3000],
    "customizations": {
        "vscode": {
            "extensions": [
                "GitHub.copilot"
            ]
        }
    }
}
